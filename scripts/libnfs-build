#!/bin/sh -xe

cmake -DCMAKE_BUILD_TYPE=Release \
            -DCMAKE_PREFIX_PATH=$SCRATCH/$ARCH \
            -DCMAKE_INSTALL_PREFIX=$SCRATCH/$ARCH \
            -DBUILD_SHARED_LIBS=false \
            -DCMAKE_OSX_SYSROOT=$SDKPATH \
            $SRC/$1
make -j5 -s
make -j5 install -s

# Copy cmake-generated config.h to Swift C module shim (first build wins —
# all Apple platform slices produce identical config.h values)
CONFIG_DST="$ROOT/Sources/nfs/include/config.h"
if [ -f config.h ] && [ ! -f "$CONFIG_DST.updated" ]; then
    cp config.h "$CONFIG_DST"
    touch "$CONFIG_DST.updated"
fi